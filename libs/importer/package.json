{
  "name": "@bitwarden/importer",
  "version": "0.0.0",
  "description": "Home for all Bitwarden importers.",
  "keywords": [
    "bitwarden"
  ],
  "author": "Bitwarden Inc.",
  "homepage": "https://bitwarden.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/bitwarden/clients"
  },
  "license": "GPL-3.0",
  "scripts": {
    "test": "jest",
    "clean": "rimraf dist src/importers/keeper/access/generated/*.ts",
    "build:proto": "protoc --ts_opt ts_nocheck --ts_out src/importers/keeper/access/generated --proto_path src/importers/keeper/access/proto src/importers/keeper/access/proto/*.proto",
    "build": "npm run clean && npm run build:proto && tsc",
    "build:watch": "npm run clean && tsc -watch"
  }
}
