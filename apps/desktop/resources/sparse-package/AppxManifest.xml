<?xml version="1.0" encoding="utf-8"?>
<Package xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
    xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
    xmlns:com="http://schemas.microsoft.com/appx/manifest/com/windows10"
    xmlns:desktop4="http://schemas.microsoft.com/appx/manifest/desktop/windows10/4"
    xmlns:desktop5="http://schemas.microsoft.com/appx/manifest/desktop/windows10/5"
    xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
    IgnorableNamespaces="com desktop4 desktop5 uap10">
    <Identity Name="8bitSolutionsLLC.BitwardenDesktopShellExtension"
        ProcessorArchitecture="${arch}"
        Publisher="${publisher}"
        Version="${version}" />
    <Properties>
        <DisplayName>Bitwarden Shell Extension</DisplayName>
        <PublisherDisplayName>Bitwarden Inc</PublisherDisplayName>
        <Description>Bitwarden context menu shell extension for Windows Explorer.</Description>
        <Logo>resources\icon.png</Logo>
        <uap10:AllowExternalContent>true</uap10:AllowExternalContent>
    </Properties>
    <Dependencies>
        <TargetDeviceFamily Name="Windows.Desktop"
            MinVersion="10.0.19041.0"
            MaxVersionTested="10.0.26100.0" />
    </Dependencies>
    <Capabilities>
        <rescap:Capability Name="runFullTrust" />
    </Capabilities>
    <Applications>
        <Application Id="BitwardenDesktop" Executable="Bitwarden.exe"
            EntryPoint="Windows.FullTrustApplication">
            <Extensions>
                <!-- COM server registration for the shell extension DLL -->
                <com:Extension Category="windows.comServer">
                    <com:ComServer>
                        <com:SurrogateServer DisplayName="Bitwarden Shell Extension">
                            <com:Class Id="A585A128-2049-4934-AE35-CEA51A83622B"
                                       Path="bitwarden_windows_shell_extension.dll"
                                       ThreadingModel="STA" />
                        </com:SurrogateServer>
                    </com:ComServer>
                </com:Extension>
                <!-- Windows 11 modern context menu entries -->
                <desktop4:Extension Category="windows.fileExplorerContextMenus">
                    <desktop4:FileExplorerContextMenus>
                        <desktop5:ItemType Type="*">
                            <desktop5:Verb Id="BitwardenSend"
                                           Clsid="A585A128-2049-4934-AE35-CEA51A83622B" />
                        </desktop5:ItemType>
                        <desktop5:ItemType Type="Directory">
                            <desktop5:Verb Id="BitwardenSendDir"
                                           Clsid="A585A128-2049-4934-AE35-CEA51A83622B" />
                        </desktop5:ItemType>
                    </desktop4:FileExplorerContextMenus>
                </desktop4:Extension>
            </Extensions>
        </Application>
    </Applications>
</Package>
