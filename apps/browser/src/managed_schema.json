{
  "type": "object",
  "properties": {
    "environment": {
      "type": "object",
      "properties": {
        "base": {
          "type": "string",
          "description": "Base URL; typically only this value needs to be set."
        },
        "webVault": {
          "type": "string",
          "description": "Web vault URL."
        },
        "api": {
          "type": "string",
          "description": "API URL."
        },
        "identity": {
          "type": "string",
          "description": "Identity URL."
        },
        "icons": {
          "type": "string",
          "description": "Icons URL."
        },
        "notifications": {
          "type": "string",
          "description": "Notifications URL."
        },
        "events": {
          "type": "string",
          "description": "Events URL."
        }
      }
    },
    "theming": {
      "type": "object",
      "properties": {
        "selection": {
          "type": "string",
          "description": "Application color theme."
        },
        "compactMode": {
          "type": "boolean",
          "description": "Compact display mode."
        }
      }
    },
    "translation": {
      "type": "object",
      "properties": {
        "locale": {
          "type": "string",
          "description": "Application language (locale)."
        }
      }
    },
    "vaultAppearance": {
      "type": "object",
      "properties": {
        "copyButtons": {
          "type": "string",
          "description": "Copy-button display mode."
        }
      }
    },
    "generator": {
      "type": "object",
      "properties": {
        "password": {
          "type": "object",
          "properties": {
            "lowercase": {
              "type": "boolean",
              "description": "Force including lowercase characters."
            },
            "uppercase": {
              "type": "boolean",
              "description": "Force including uppercase characters."
            },
            "numbers": {
              "type": "boolean",
              "description": "Force including numbers."
            },
            "special": {
              "type": "boolean",
              "description": "Force including special characters."
            },
            "avoidAmbiguous": {
              "type": "boolean",
              "description": "Force avoiding ambiguous characters."
            },
            "length": {
              "type": "integer",
              "description": "Force password length."
            },
            "minLowercase": {
              "type": "integer",
              "description": "Force the minimum number of lowercase characters."
            },
            "minUppercase": {
              "type": "integer",
              "description": "Force the minimum number of uppercase characters."
            },
            "minNumber": {
              "type": "integer",
              "description": "Force the minimum number of numeric characters."
            },
            "minSpecial": {
              "type": "integer",
              "description": "Force the minimum number of special characters."
            }
          }
        },
        "passphrase": {
          "type": "object",
          "properties": {
            "numWords": {
              "type": "integer",
              "description": "Force the number of words."
            },
            "wordSeparator": {
              "type": "string",
              "description": "Force the word separator."
            },
            "capitalize": {
              "type": "boolean",
              "description": "Force capitalization."
            },
            "includeNumber": {
              "type": "boolean",
              "description": "Force including a number."
            }
          }
        }
      }
    }
  }
}
